<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>MizanLang</RootNamespace>
        <PackageId>MizanLang</PackageId>
        <Version>1.0.0</Version>
        <Authors>Moripaf</Authors>
        <Description>A Farsi DSL for expressing simple validation logic in a declarative manner</Description>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Pidgin" Version="3.5.1" />
      <PackageReference Include="Sawmill" Version="3.4.0" />
    </ItemGroup>

</Project>
